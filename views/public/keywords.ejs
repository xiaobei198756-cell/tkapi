<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>关键词搜索 | TKAPI</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/css/app.css" rel="stylesheet">
</head>
<body class="site-page">
  <header class="site-header">
    <a class="site-logo" href="/">TKAPI</a>
    <nav class="site-nav" aria-label="TKAPI navigation">
      <a href="/features">功能介绍</a>
      <a href="/keywords">关键词搜索</a>
      <a href="/settings/tiktok">TikTok API</a>
      <a href="/terms">Terms</a>
      <a href="/privacy">Privacy</a>
    </nav>
  </header>

  <main class="site-section site-section-top">
    <div class="page-heading">
      <p class="site-kicker">Keyword Search</p>
      <h1>关键词搜索</h1>
      <p>输入关键词和筛选条件，调用后端接口查询允许范围内的视频数据。</p>
    </div>

    <section class="tool-card">
      <form id="keywordForm" class="keyword-form">
        <label>
          <span>关键词</span>
          <input class="form-control" name="keyword" placeholder="crypto prediction market" required>
        </label>
        <div>
          <span class="field-label">选择平台</span>
          <div class="platform-options">
            <label><input type="checkbox" name="platforms" value="tiktok" checked> TikTok</label>
            <label><input type="checkbox" name="platforms" value="youtube"> YouTube</label>
            <label><input type="checkbox" name="platforms" value="instagram"> Instagram</label>
            <label><input type="checkbox" name="platforms" value="facebook"> Facebook</label>
            <label><input type="checkbox" name="platforms" value="x"> X</label>
          </div>
        </div>
        <label>
          <span>最小播放量</span>
          <input class="form-control" name="min_views" min="0" placeholder="1000" type="number">
        </label>
        <label>
          <span>最小点赞数</span>
          <input class="form-control" name="min_likes" min="0" placeholder="100" type="number">
        </label>
        <label>
          <span>发布时间范围</span>
          <select class="form-select" name="date_range">
            <option value="7d">最近 7 天</option>
            <option value="30d">最近 30 天</option>
            <option value="90d">最近 90 天</option>
            <option value="">不限</option>
          </select>
        </label>
        <label>
          <span>最大返回数量</span>
          <input class="form-control" name="limit" max="100" min="1" type="number" value="50">
        </label>
        <button class="btn btn-primary btn-lg" type="submit">开始搜索</button>
      </form>
      <div id="searchMessage" class="search-message" role="status"></div>
    </section>

    <section class="tool-card mt-4">
      <div class="table-responsive">
        <table class="table align-middle">
          <thead>
            <tr>
              <th>平台</th>
              <th>关键词</th>
              <th>视频标题</th>
              <th>视频链接</th>
              <th>作者</th>
              <th>发布时间</th>
              <th>播放量</th>
              <th>点赞数</th>
              <th>评论数</th>
              <th>收藏数</th>
              <th>分享数</th>
              <th>数据更新时间</th>
            </tr>
          </thead>
          <tbody id="resultBody">
            <tr>
              <td colspan="12" class="text-muted">暂无数据，请先开始搜索。</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>
  </main>

  <script>
    const form = document.getElementById('keywordForm');
    const message = document.getElementById('searchMessage');
    const resultBody = document.getElementById('resultBody');

    function formatNumber(value) {
      return value === null || value === undefined || value === '' ? '-' : Number(value).toLocaleString();
    }

    function formatDate(value) {
      return value ? new Date(value).toLocaleString() : '-';
    }

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      message.textContent = '正在搜索...';
      resultBody.innerHTML = '';
      const data = new FormData(form);
      const platforms = data.getAll('platforms');
      const payload = {
        keyword: data.get('keyword'),
        platforms,
        min_views: data.get('min_views') ? Number(data.get('min_views')) : undefined,
        min_likes: data.get('min_likes') ? Number(data.get('min_likes')) : undefined,
        date_range: data.get('date_range') || undefined,
        limit: Number(data.get('limit') || 50)
      };

      try {
        const response = await fetch('/api/search/keywords', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
        const json = await response.json();
        if (!response.ok) throw new Error(json.message || 'Search request failed.');
        const warnings = json.warnings && json.warnings.length ? ` 提示：${json.warnings.join('；')}` : '';
        message.textContent = `返回 ${json.items.length} 条结果。${warnings}`;
        if (!json.items.length) {
          resultBody.innerHTML = '<tr><td colspan="12" class="text-muted">没有搜索到视频数据。</td></tr>';
          return;
        }
        resultBody.innerHTML = json.items.map((item) => `
          <tr>
            <td>${item.platform || '-'}</td>
            <td>${item.keyword || '-'}</td>
            <td>${item.title || '-'}</td>
            <td>${item.url ? `<a class="btn btn-sm btn-success" href="${item.url}" target="_blank" rel="noreferrer">Open</a>` : '-'}</td>
            <td>${item.author || '-'}</td>
            <td>${formatDate(item.published_at)}</td>
            <td>${formatNumber(item.view_count)}</td>
            <td>${formatNumber(item.like_count)}</td>
            <td>${formatNumber(item.comment_count)}</td>
            <td>${formatNumber(item.favorite_count)}</td>
            <td>${formatNumber(item.share_count)}</td>
            <td>${formatDate(item.updated_at)}</td>
          </tr>
        `).join('');
      } catch (error) {
        message.textContent = error.message || '网络请求失败。';
        resultBody.innerHTML = '<tr><td colspan="12" class="text-danger">搜索失败，请检查后端接口和 API 权限。</td></tr>';
      }
    });
  </script>
</body>
</html>
