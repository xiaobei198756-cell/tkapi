<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Keyword Search | TKAPI</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/css/app.css" rel="stylesheet">
</head>
<body class="site-page">
  <header class="site-header">
    <a class="site-logo" href="/">TKAPI</a>
    <nav class="site-nav" aria-label="TKAPI navigation">
      <a href="/features">Features</a>
      <a href="/keywords">Keyword Search</a>
      <a href="/settings/tiktok">TikTok API</a>
      <a href="/terms">Terms</a>
      <a href="/privacy">Privacy</a>
    </nav>
  </header>

  <main class="site-section site-section-top">
    <div class="page-heading">
      <p class="site-kicker">Keyword Search</p>
      <h1>Keyword Search</h1>
      <p>Submit keywords and filters to request video data that is available through authorized API access.</p>
    </div>

    <section class="tool-card">
      <form id="keywordForm" class="keyword-form">
        <label>
          <span>Keyword</span>
          <input class="form-control" name="keyword" placeholder="creator analytics" required>
        </label>
        <div>
          <span class="field-label">Platforms</span>
          <div class="platform-options">
            <label><input type="checkbox" name="platforms" value="tiktok" checked> TikTok</label>
            <label><input type="checkbox" name="platforms" value="youtube"> YouTube</label>
            <label><input type="checkbox" name="platforms" value="instagram"> Instagram</label>
            <label><input type="checkbox" name="platforms" value="facebook"> Facebook</label>
            <label><input type="checkbox" name="platforms" value="x"> X</label>
          </div>
        </div>
        <label>
          <span>Minimum views</span>
          <input class="form-control" name="min_views" min="0" placeholder="1000" type="number">
        </label>
        <label>
          <span>Minimum likes</span>
          <input class="form-control" name="min_likes" min="0" placeholder="100" type="number">
        </label>
        <label>
          <span>Publish date range</span>
          <select class="form-select" name="date_range">
            <option value="7d">Last 7 days</option>
            <option value="30d">Last 30 days</option>
            <option value="90d">Last 90 days</option>
            <option value="">Any time</option>
          </select>
        </label>
        <label>
          <span>Maximum results</span>
          <input class="form-control" name="limit" max="100" min="1" type="number" value="50">
        </label>
        <button class="btn btn-primary btn-lg" type="submit">Start Search</button>
      </form>
      <div id="searchMessage" class="search-message" role="status"></div>
    </section>

    <section class="tool-card mt-4">
      <div class="table-responsive">
        <table class="table align-middle">
          <thead>
            <tr>
              <th>Platform</th>
              <th>Keyword</th>
              <th>Video title</th>
              <th>Video link</th>
              <th>Author</th>
              <th>Published</th>
              <th>Views</th>
              <th>Likes</th>
              <th>Comments</th>
              <th>Favorites</th>
              <th>Shares</th>
              <th>Updated</th>
            </tr>
          </thead>
          <tbody id="resultBody">
            <tr>
              <td colspan="12" class="text-muted">No data yet. Start a search to view results.</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>
  </main>

  <script>
    const form = document.getElementById('keywordForm');
    const message = document.getElementById('searchMessage');
    const resultBody = document.getElementById('resultBody');

    function formatNumber(value) {
      return value === null || value === undefined || value === '' ? '-' : Number(value).toLocaleString();
    }

    function formatDate(value) {
      return value ? new Date(value).toLocaleString() : '-';
    }

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      message.textContent = 'Searching...';
      resultBody.innerHTML = '';
      const data = new FormData(form);
      const platforms = data.getAll('platforms');
      const payload = {
        keyword: data.get('keyword'),
        platforms,
        min_views: data.get('min_views') ? Number(data.get('min_views')) : undefined,
        min_likes: data.get('min_likes') ? Number(data.get('min_likes')) : undefined,
        date_range: data.get('date_range') || undefined,
        limit: Number(data.get('limit') || 50)
      };

      try {
        const response = await fetch('/api/search/keywords', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
        const json = await response.json();
        if (!response.ok) throw new Error(json.message || 'Search request failed.');
        const warnings = json.warnings && json.warnings.length ? ' Notice: ' + json.warnings.join('; ') : '';
        message.textContent = 'Returned ' + json.items.length + ' result(s).' + warnings;
        if (!json.items.length) {
          resultBody.innerHTML = '<tr><td colspan="12" class="text-muted">No video data was found.</td></tr>';
          return;
        }
        resultBody.innerHTML = json.items.map((item) => `
          <tr>
            <td>${item.platform || '-'}</td>
            <td>${item.keyword || '-'}</td>
            <td>${item.title || '-'}</td>
            <td>${item.url ? `<a class="btn btn-sm btn-success" href="${item.url}" target="_blank" rel="noreferrer">Open</a>` : '-'}</td>
            <td>${item.author || '-'}</td>
            <td>${formatDate(item.published_at)}</td>
            <td>${formatNumber(item.view_count)}</td>
            <td>${formatNumber(item.like_count)}</td>
            <td>${formatNumber(item.comment_count)}</td>
            <td>${formatNumber(item.favorite_count)}</td>
            <td>${formatNumber(item.share_count)}</td>
            <td>${formatDate(item.updated_at)}</td>
          </tr>
        `).join('');
      } catch (error) {
        message.textContent = error.message || 'Network request failed.';
        resultBody.innerHTML = '<tr><td colspan="12" class="text-danger">Search failed. Check backend logs and API permissions.</td></tr>';
      }
    });
  </script>
</body>
</html>
