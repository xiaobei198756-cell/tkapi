<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>TikTok API Settings | TKAPI</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/css/app.css" rel="stylesheet">
</head>
<body class="site-page">
  <header class="site-header">
    <a class="site-logo" href="/">TKAPI</a>
    <nav class="site-nav" aria-label="TKAPI navigation">
      <a href="/features">Features</a>
      <a href="/keywords">Keyword Search</a>
      <a href="/settings/tiktok">TikTok API</a>
      <a href="/terms">Terms</a>
      <a href="/privacy">Privacy</a>
    </nav>
  </header>

  <main class="site-section site-section-top">
    <div class="page-heading">
      <p class="site-kicker">TikTok API</p>
      <h1>TikTok API Settings</h1>
      <p>Connect an eligible TikTok account through official OAuth. This page shows authorization status only and never displays access tokens or refresh tokens.</p>
    </div>

    <section class="tool-card">
      <div class="status-row">
        <span>Configuration status</span>
        <strong id="configText">Checking...</strong>
      </div>
      <div class="status-row">
        <span>Authorization status</span>
        <strong id="statusText">Checking...</strong>
      </div>
      <div class="status-row">
        <span>open_id</span>
        <strong id="openId">-</strong>
      </div>
      <div class="status-row">
        <span>scope</span>
        <strong id="scopeText">-</strong>
      </div>
      <div class="status-row">
        <span>Token expiration</span>
        <strong id="expiresAt">-</strong>
      </div>
      <div id="errorBox" class="alert alert-warning mt-3 d-none"></div>
      <div class="site-actions">
        <button class="btn btn-success btn-lg" id="connectButton" type="button">Connect TikTok Account</button>
      </div>
      <p class="text-muted mt-3 mb-0">
        TikTok Developer Redirect URI must be exactly: https://tkapi.onrender.com/api/tiktok/callback
      </p>
      <p class="text-muted mt-2 mb-0">
        Contact: <a href="mailto:xiaobei198756@gmail.com">xiaobei198756@gmail.com</a>
      </p>
    </section>
  </main>

  <script>
    const configText = document.getElementById('configText');
    const statusText = document.getElementById('statusText');
    const openId = document.getElementById('openId');
    const scopeText = document.getElementById('scopeText');
    const expiresAt = document.getElementById('expiresAt');
    const connectButton = document.getElementById('connectButton');
    const errorBox = document.getElementById('errorBox');

    function showError(message) {
      errorBox.textContent = message;
      errorBox.classList.remove('d-none');
    }

    function clearError() {
      errorBox.textContent = '';
      errorBox.classList.add('d-none');
    }

    async function loadStatus() {
      clearError();
      try {
        const response = await fetch('/api/tiktok/status');
        const json = await response.json();
        const missing = Array.isArray(json.missing) ? json.missing : [];
        configText.textContent = json.configured ? 'Configured' : 'Missing: ' + (missing.join(', ') || 'unknown setting');
        statusText.textContent = json.connected ? 'TikTok connected' : 'Not connected';
        openId.textContent = json.open_id || '-';
        scopeText.textContent = json.scope || '-';
        expiresAt.textContent = json.expires_at ? new Date(json.expires_at).toLocaleString() : '-';
        if (!json.configured) {
          showError('Missing Render environment variable(s): ' + (missing.join(', ') || 'unknown setting') + '. Please complete the service environment configuration.');
        }
      } catch (error) {
        configText.textContent = 'Check failed';
        statusText.textContent = 'Backend API unavailable';
        showError('Unable to connect to /api/tiktok/status. Please check that the backend service is running.');
      }
    }

    connectButton.addEventListener('click', async () => {
      clearError();
      connectButton.disabled = true;
      connectButton.textContent = 'Generating authorization link...';
      try {
        const response = await fetch('/api/tiktok/auth-url');
        const json = await response.json();
        if (!response.ok) {
          const missing = Array.isArray(json.missing) ? ' Missing: ' + json.missing.join(', ') : '';
          throw new Error((json.message || 'Unable to generate TikTok authorization link.') + missing);
        }
        window.location.href = json.auth_url;
      } catch (error) {
        showError(error.message || 'TikTok authorization failed.');
        connectButton.disabled = false;
        connectButton.textContent = 'Connect TikTok Account';
      }
    });

    loadStatus();
  </script>
</body>
</html>
