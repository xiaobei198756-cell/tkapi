<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>TikTok API 设置 | TKAPI</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/css/app.css" rel="stylesheet">
</head>
<body class="site-page">
  <header class="site-header">
    <a class="site-logo" href="/">TKAPI</a>
    <nav class="site-nav" aria-label="TKAPI navigation">
      <a href="/features">功能介绍</a>
      <a href="/keywords">关键词搜索</a>
      <a href="/settings/tiktok">TikTok API</a>
      <a href="/terms">Terms</a>
      <a href="/privacy">Privacy</a>
    </nav>
  </header>

  <main class="site-section site-section-top">
    <div class="page-heading">
      <p class="site-kicker">TikTok API</p>
      <h1>TikTok API 设置</h1>
      <p>通过 TikTok 官方 OAuth 授权连接账号。页面只显示授权状态，不显示 access_token 或 refresh_token。</p>
    </div>

    <section class="tool-card">
      <div class="status-row">
        <span>配置状态</span>
        <strong id="configText">检查中...</strong>
      </div>
      <div class="status-row">
        <span>授权状态</span>
        <strong id="statusText">检查中...</strong>
      </div>
      <div class="status-row">
        <span>open_id</span>
        <strong id="openId">-</strong>
      </div>
      <div class="status-row">
        <span>scope</span>
        <strong id="scopeText">-</strong>
      </div>
      <div class="status-row">
        <span>token 过期时间</span>
        <strong id="expiresAt">-</strong>
      </div>
      <div id="errorBox" class="alert alert-warning mt-3 d-none"></div>
      <div class="site-actions">
        <button class="btn btn-success btn-lg" id="connectButton" type="button">连接 TikTok 账号</button>
      </div>
      <p class="text-muted mt-3 mb-0">
        TikTok Developer 后台 Redirect URI 必须填写：https://tkapi.onrender.com/api/tiktok/callback
      </p>
    </section>
  </main>

  <script>
    const configText = document.getElementById('configText');
    const statusText = document.getElementById('statusText');
    const openId = document.getElementById('openId');
    const scopeText = document.getElementById('scopeText');
    const expiresAt = document.getElementById('expiresAt');
    const connectButton = document.getElementById('connectButton');
    const errorBox = document.getElementById('errorBox');

    function showError(message) {
      errorBox.textContent = message;
      errorBox.classList.remove('d-none');
    }

    function clearError() {
      errorBox.textContent = '';
      errorBox.classList.add('d-none');
    }

    async function loadStatus() {
      clearError();
      try {
        const response = await fetch('/api/tiktok/status');
        const json = await response.json();
        const missing = Array.isArray(json.missing) ? json.missing : [];
        configText.textContent = json.configured ? '已配置' : `缺少：${missing.join(', ') || '未知配置'}`;
        statusText.textContent = json.connected ? 'TikTok 已连接' : '未连接';
        openId.textContent = json.open_id || '-';
        scopeText.textContent = json.scope || '-';
        expiresAt.textContent = json.expires_at ? new Date(json.expires_at).toLocaleString() : '-';
        if (!json.configured) {
          showError(`Render 环境变量未配置完整：${missing.join(', ')}。请先在 Render Environment 中补齐。`);
        }
      } catch (error) {
        configText.textContent = '检查失败';
        statusText.textContent = '无法连接后端接口';
        showError('无法连接 /api/tiktok/status，请检查后端服务是否正常运行。');
      }
    }

    connectButton.addEventListener('click', async () => {
      clearError();
      connectButton.disabled = true;
      connectButton.textContent = '正在生成授权链接...';
      try {
        const response = await fetch('/api/tiktok/auth-url');
        const json = await response.json();
        if (!response.ok) {
          const missing = Array.isArray(json.missing) ? ` 缺少：${json.missing.join(', ')}` : '';
          throw new Error(`${json.message || '无法生成 TikTok 授权链接。'}${missing}`);
        }
        window.location.href = json.auth_url;
      } catch (error) {
        showError(error.message || 'TikTok 授权失败。');
        connectButton.disabled = false;
        connectButton.textContent = '连接 TikTok 账号';
      }
    });

    loadStatus();
  </script>
</body>
</html>
