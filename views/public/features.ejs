<body class="site-page">
  <header class="site-header">
    <a class="site-logo" href="/">TKAPI</a>
    <nav class="site-nav" aria-label="TKAPI navigation">
      <a href="/features">Features</a>
      <a href="/keywords">Keyword Search</a>
      <a href="/settings/tiktok">TikTok API</a>
      <a href="/terms">Terms</a>
      <a href="/privacy">Privacy</a>
    </nav>
  </header>

  <main class="site-section site-section-top">
    <div class="page-heading">
      <p class="site-kicker">Features</p>
      <h1>Authorized TikTok API workflows</h1>
      <p>
        TKAPI helps authorized users connect with TikTok APIs to manage account login, authorized data access,
        and compliant creator/content workflows.
      </p>
      <p>
        This service is available for users and businesses in regions where TikTok services are available. It is not
        intended for Mainland China.
      </p>
    </div>
    <div class="feature-grid">
      <article class="feature-card">
        <h2>TikTok API Login</h2>
        <p>Connect eligible TikTok accounts through official OAuth and API flows.</p>
      </article>
      <article class="feature-card">
        <h2>Authorized Data Access</h2>
        <p>View account-permitted data only after the required platform permissions are granted.</p>
      </article>
      <article class="feature-card">
        <h2>Creator and Content Workflows</h2>
        <p>Support creator/content review, reporting, and business operations through compliant API access.</p>
      </article>
      <article class="feature-card">
        <h2>Video Data Dashboard</h2>
        <p>Organize video metrics such as views, likes, comments, favorites, shares, and update time.</p>
      </article>
      <article class="feature-card">
        <h2>Public Review Pages</h2>
        <p>Homepage, Terms of Service, and Privacy Policy are available without login.</p>
      </article>
    </div>
  </main>
</body>
