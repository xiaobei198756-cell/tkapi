<%- include('../partials/admin-header', { title: '数据统计' }) %>
<h1 class="h3 mb-3">数据统计</h1>
<h2 class="h5">按 Campaign</h2>
<table class="table table-striped align-middle">
  <thead><tr><th>Campaign</th><th>Slug</th><th>点击</th><th>分配</th></tr></thead>
  <tbody>
    <% byCampaign.forEach((row) => { %>
      <tr><td><%= row.campaign_name %></td><td><%= row.slug %></td><td><%= row.click_count %></td><td><%= row.assignment_count %></td></tr>
    <% }) %>
  </tbody>
</table>
<h2 class="h5 mt-4">按客服账号</h2>
<table class="table table-striped align-middle">
  <thead><tr><th>账号</th><th>平台</th><th>国家</th><th>分配</th></tr></thead>
  <tbody>
    <% byAccount.forEach((row) => { %>
      <tr><td><%= row.account_name %></td><td><%= row.platform %></td><td><%= row.country_code %></td><td><%= row.assignment_count %></td></tr>
    <% }) %>
  </tbody>
</table>
<h2 class="h5 mt-4">最近日期点击</h2>
<table class="table table-striped align-middle">
  <thead><tr><th>日期</th><th>点击</th></tr></thead>
  <tbody>
    <% byDay.forEach((row) => { %>
      <tr><td><%= row.day %></td><td><%= row.click_count %></td></tr>
    <% }) %>
  </tbody>
</table>
<%- include('../partials/admin-footer') %>
