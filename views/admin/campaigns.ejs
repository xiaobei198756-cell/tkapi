<%- include('../partials/admin-header', { title: 'Campaign' }) %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h3 mb-0">Campaign</h1>
  <a class="btn btn-primary" href="/admin/campaigns/new">创建 Campaign</a>
</div>
<div class="table-responsive">
  <table class="table table-striped align-middle">
    <thead><tr><th>ID</th><th>名称</th><th>链接</th><th>允许国家</th><th>启用</th><th>点击</th><th>分配</th><th></th></tr></thead>
    <tbody>
      <% campaigns.forEach((campaign) => { %>
        <tr>
          <td><%= campaign.id %></td>
          <td><%= campaign.campaign_name %></td>
          <td><a href="/go/<%= campaign.slug %>" target="_blank">/go/<%= campaign.slug %></a></td>
          <td><%= campaign.allowed_countries || '不限' %></td>
          <td><span class="badge <%= campaign.enabled ? 'text-bg-success' : 'text-bg-secondary' %>"><%= campaign.enabled ? '启用' : '停用' %></span></td>
          <td><%= campaign.click_count %></td>
          <td><%= campaign.assignment_count %></td>
          <td>
            <form method="post" action="/admin/campaigns/<%= campaign.id %>/toggle">
              <button class="btn btn-sm btn-outline-secondary" type="submit"><%= campaign.enabled ? '停用' : '启用' %></button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<%- include('../partials/admin-footer') %>
