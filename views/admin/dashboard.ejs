<%- include('../partials/admin-header', { title: '后台首页' }) %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h3 mb-0">数据概览</h1>
</div>
<div class="row g-3 mb-4">
  <div class="col-md-3"><div class="metric"><span>客服账号</span><strong><%= stats.accounts.count %></strong></div></div>
  <div class="col-md-3"><div class="metric"><span>Campaign</span><strong><%= stats.campaigns.count %></strong></div></div>
  <div class="col-md-3"><div class="metric"><span>点击记录</span><strong><%= stats.clicks.count %></strong></div></div>
  <div class="col-md-3"><div class="metric"><span>线索分配</span><strong><%= stats.assignments.count %></strong></div></div>
</div>
<h2 class="h5">客服分配次数</h2>
<div class="table-responsive">
  <table class="table table-striped align-middle">
    <thead><tr><th>账号</th><th>平台</th><th>分配次数</th></tr></thead>
    <tbody>
      <% accountStats.forEach((row) => { %>
        <tr>
          <td><%= row.account_name %></td>
          <td><%= row.platform %></td>
          <td><%= row.assignment_count %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<%- include('../partials/admin-footer') %>
