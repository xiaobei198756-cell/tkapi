<%- include('../partials/admin-header', { title: '创建 Campaign' }) %>
<h1 class="h3 mb-3">创建 Campaign</h1>
<% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
<form method="post" action="/admin/campaigns" class="form-panel">
  <div class="mb-3">
    <label class="form-label" for="campaign_name">campaign_name</label>
    <input class="form-control" id="campaign_name" name="campaign_name" value="<%= campaign.campaign_name || '' %>" required>
  </div>
  <div class="mb-3">
    <label class="form-label" for="slug">slug</label>
    <input class="form-control" id="slug" name="slug" value="<%= campaign.slug || '' %>" placeholder="campaign-a">
  </div>
  <div class="mb-3">
    <label class="form-label" for="allowed_countries">allowed_countries</label>
    <input class="form-control" id="allowed_countries" name="allowed_countries" value="<%= campaign.allowed_countries || '' %>" placeholder="US,CA,GB；留空表示不限">
  </div>
  <div class="form-check mb-3">
    <input class="form-check-input" id="enabled" name="enabled" type="checkbox" checked>
    <label class="form-check-label" for="enabled">启用</label>
  </div>
  <button class="btn btn-primary" type="submit">保存</button>
  <a class="btn btn-link" href="/admin/campaigns">返回</a>
</form>
<%- include('../partials/admin-footer') %>
