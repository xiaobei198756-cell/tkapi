<%- include('../partials/admin-header', { title: '登录' }) %>
<div class="auth-panel mx-auto">
  <h1 class="h4 mb-3">管理员登录</h1>
  <% if (error) { %>
    <div class="alert alert-danger"><%= error %></div>
  <% } %>
  <form method="post" action="/admin/login">
    <div class="mb-3">
      <label class="form-label" for="username">用户名</label>
      <input class="form-control" id="username" name="username" required autofocus>
    </div>
    <div class="mb-3">
      <label class="form-label" for="password">密码</label>
      <input class="form-control" id="password" name="password" type="password" required>
    </div>
    <button class="btn btn-primary w-100" type="submit">登录</button>
  </form>
</div>
<%- include('../partials/admin-footer') %>
