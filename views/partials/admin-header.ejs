<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title || '客服分流后台' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/css/app.css" rel="stylesheet">
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
  <div class="container">
    <a class="navbar-brand" href="/admin">客服分流后台</a>
    <% if (currentUser) { %>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="nav">
        <ul class="navbar-nav me-auto">
          <li class="nav-item"><a class="nav-link" href="/admin/accounts">客服账号</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/campaigns">Campaign</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/clicks">点击记录</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/stats">统计</a></li>
        </ul>
        <form method="post" action="/admin/logout">
          <button class="btn btn-outline-light btn-sm" type="submit">退出</button>
        </form>
      </div>
    <% } %>
  </div>
</nav>
<main class="container py-4">
  <% if (flash) { %>
    <div class="alert alert-<%= flash.type %>"><%= flash.message %></div>
  <% } %>
